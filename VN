@st.cache_data
def load_data():
    csv_path = os.path.join(DATA_DIR, "covid.csv")
    if os.path.exists(csv_path):
        data = pd.read_csv(csv_path, usecols=lambda c: c not in ["Unnamed: 0"])
        data.columns = data.columns.str.strip().str.replace(" ", "_")
        # Create balanced sample as in notebook
        d1 = data[data["DEATH"] == 1].sample(n=5000, random_state=42)
        d0 = data[data["DEATH"] == 0].sample(n=5000, random_state=42)
        df = pd.concat([d1, d0]).reset_index(drop=True)
        return data, df
    return None, None

