    if df is not None:
        from sklearn.model_selection import train_test_split as tts2
        X_full = df.drop(columns=["DEATH"] + [c for c in df.columns if c in ["Outcome", "Sex_Label"]])
        y_full = df["DEATH"]
        _, X_test_shap, _, _ = tts2(X_full, y_full, test_size=0.30, random_state=42, stratify=y_full)

        try:
            shap_values = shap_explainer.shap_values(X_test_shap)
            if isinstance(shap_values, list):
                sv = shap_values[1]
            else:
                sv = shap_values

            # Beeswarm
            st.markdown("#### SHAP Summary Plot (Beeswarm)")
            fig_bee, ax_bee = plt.subplots(figsize=(10, 6))
            shap.summary_plot(sv, X_test_shap, feature_names=FEATURE_NAMES, show=False)
            st.pyplot(fig_bee)
            plt.close("all")

            st.caption(
                "**Interpretation:** Each dot represents one patient. The horizontal position shows how much "
                "that feature pushed the prediction toward death (right) or survival (left). Color indicates "
                "the feature's actual value — red is high, blue is low. Age dominates: high age values "
                "consistently push predictions toward death. Pneumonia and hospitalization are the next most "
                "influential features."
            )

            # Bar Plot
            st.markdown("#### SHAP Feature Importance (Mean |SHAP|)")
            fig_bar, ax_bar = plt.subplots(figsize=(9, 5))
            shap.summary_plot(sv, X_test_shap, feature_names=FEATURE_NAMES,
                              plot_type="bar", show=False)
            st.pyplot(fig_bar)
            plt.close("all")

            st.caption(
                "**Interpretation:** This bar chart ranks features by their average absolute SHAP value across "
                "all test predictions. Age has the largest mean impact, followed by pneumonia, cardiovascular "
                "disease, and hospitalization. Features at the bottom (e.g., pregnancy, asthma) have minimal "
                "influence on the model's mortality predictions."
            )
        except Exception as e:
            st.warning(f"Could not generate SHAP plots from explainer: {e}")
            # Fall back to saved images
            for img_name, title in [
                ("shap_summary_beeswarm.png", "SHAP Summary Plot (Beeswarm)"),
                ("shap_bar_plot.png", "SHAP Feature Importance"),
            ]:
                img_path = os.path.join(OUTPUT_DIR, img_name)
                if os.path.exists(img_path):
                    st.markdown(f"#### {title}")
                    st.image(img_path, use_container_width=True)

    # --- Interactive Prediction ---
    st.markdown("---")
    st.subheader("Interactive Patient Risk Prediction")
    st.markdown("Adjust the patient features below and select a model to see the predicted mortality risk "
                "in real time. Features not shown below are set to their dataset median/mode values.")

    col_left, col_right = st.columns([1, 1])

    with col_left:
        age = st.slider("Age", min_value=0, max_value=110, value=55, step=1)
        sex = st.selectbox("Sex", options=[0, 1], format_func=lambda x: "Male" if x == 0 else "Female")
        pneumonia = st.selectbox("Pneumonia", [0, 1], format_func=lambda x: "No" if x == 0 else "Yes")
        diabetes = st.selectbox("Diabetes", [0, 1], format_func=lambda x: "No" if x == 0 else "Yes")
        hypertension = st.selectbox("Hypertension", [0, 1], format_func=lambda x: "No" if x == 0 else "Yes")
        obesity = st.selectbox("Obesity", [0, 1], format_func=lambda x: "No" if x == 0 else "Yes")

    with col_right:
        copd = st.selectbox("COPD", [0, 1], format_func=lambda x: "No" if x == 0 else "Yes")
        cardiovascular = st.selectbox("Cardiovascular Disease", [0, 1], format_func=lambda x: "No" if x == 0 else "Yes")
        renal = st.selectbox("Chronic Renal Disease", [0, 1], format_func=lambda x: "No" if x == 0 else "Yes")
        tobacco = st.selectbox("Tobacco Use", [0, 1], format_func=lambda x: "No" if x == 0 else "Yes")
        hospitalized = st.selectbox("Hospitalized", [0, 1], index=1, format_func=lambda x: "No" if x == 0 else "Yes")
        covid_positive = st.selectbox("COVID Positive", [0, 1], index=1, format_func=lambda x: "No" if x == 0 else "Yes")

    # Build feature vector in the correct order
    # Default values for features not exposed in the UI
    defaults = {
        "SEX": sex, "HOSPITALIZED": hospitalized, "PNEUMONIA": pneumonia,
        "AGE": age, "PREGNANT": 0, "DIABETES": diabetes, "COPD": copd,
        "ASTHMA": 0, "IMMUNOSUPPRESSION": 0, "HYPERTENSION": hypertension,
        "OTHER_DISEASE": 0, "CARDIOVASCULAR": cardiovascular, "OBESITY": obesity,
        "RENAL_CHRONIC": renal, "TOBACCO": tobacco, "COVID_POSITIVE": covid_positive,
    }
    input_row = pd.DataFrame([{f: defaults.get(f, 0) for f in FEATURE_NAMES}])

    # Model selection
    model_choice = st.selectbox(
        "Select Model for Prediction",
        ["Logistic Regression", "Decision Tree", "Random Forest", "LightGBM", "MLP Neural Network"]
    )

    if st.button("Predict", type="primary"):
        # Prepare input
        if model_choice in SCALED_MODELS or model_choice == "MLP Neural Network":
            input_array = scaler.transform(input_row)
        else:
            input_array = input_row.values

        # Predict
        if model_choice == "MLP Neural Network":
            prob = float(mlp_model.predict(input_array, verbose=0).flatten()[0])
            pred_class = int(prob >= 0.5)
        else:
            mdl = sklearn_models[model_choice]
            prob = float(mdl.predict_proba(input_array)[:, 1][0])
            pred_class = int(prob >= 0.5)

        # Display result
        st.markdown("---")
        res_col1, res_col2 = st.columns(2)
        with res_col1:
            label = "⚠️ **HIGH RISK — Predicted: DIED**" if pred_class == 1 else "✅ **LOW RISK — Predicted: SURVIVED**"
            color = "#ff4b4b" if pred_class == 1 else "#00cc66"
            st.markdown(f"### {label}")
            st.markdown(f"**Probability of death:** `{prob:.2%}`")
        with res_col2:
            st.metric("Predicted Class", "Died (1)" if pred_class == 1 else "Survived (0)")
            st.metric("Death Probability", f"{prob:.4f}")

        # SHAP Waterfall for this specific input
        if model_choice in ["LightGBM", "Random Forest", "Decision Tree"]:
            st.markdown("#### SHAP Waterfall — This Patient")
            try:
                shap_exp = shap_explainer(input_row)
                if isinstance(shap_exp, list):
                    shap_exp = shap_exp[1]
                fig_wf, ax_wf = plt.subplots(figsize=(10, 6))
                shap.waterfall_plot(shap_exp[0], show=False)
                st.pyplot(fig_wf)
                plt.close("all")
                st.caption(
                    "**Interpretation:** The waterfall plot decomposes this individual prediction into "
                    "per-feature contributions. Red bars push the prediction toward death; blue bars push "
                    "toward survival. The base value is the average model output, and each feature shifts "
                    "the prediction from there."
                )
            except Exception as e:
                st.info(f"Waterfall plot available only for tree-based models with the SHAP TreeExplainer. ({e})")
        else:
            st.info("SHAP waterfall plots are available when a tree-based model (Decision Tree, Random Forest, or LightGBM) is selected.")
